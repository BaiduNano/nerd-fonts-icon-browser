[
  {
    "label": "Configure",
    "command": "cmake",
    "args": [
      "-S",
      ".",
      "-B",
      "build",
      "-G",
      "Ninja",
      "-DCMAKE_BUILD_TYPE=Debug",
      "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
    ],
  },
  {
    "label": "Debug",
    "command": "cmake",
    "args": ["--build", "build", "--config", "Debug", "--parallel", "12"],
  },
  {
    "label": "Release",
    "command": "cmake",
    "args": ["--build", "build", "--config", "Release", "--parallel", "12"],
  },
  {
    "label": "Remove",
    "command": "rm",
    "args": ["-rf", "build"],
  },
]
